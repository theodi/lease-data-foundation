# Docker Compose Environment Configuration
# IMPORTANT: This file contains sensitive credentials
# - Copy this file to .env and replace all values with secure credentials
# - Never commit the .env file to version control
# - Use strong, unique passwords for production

# PostgreSQL Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE_MIN_32_CHARS
POSTGRES_DB=lease_data
POSTGRES_PORT=5432

# pgAdmin Configuration
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=CHANGE_ME_SECURE_PGADMIN_PASSWORD_HERE
PGADMIN_PORT=5050

# Jupyter Notebook Configuration
# Generate secure token: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JUPYTER_TOKEN=CHANGE_ME_SECURE_JUPYTER_TOKEN_HERE_MIN_32_CHARS
JUPYTER_PORT=8888

# Security Notes:
# 1. PostgreSQL password should be at least 32 characters with mixed case, numbers, and symbols
# 2. pgAdmin password should be at least 16 characters with mixed case, numbers, and symbols
# 3. Jupyter token should be at least 32 characters (use secrets.token_urlsafe(32))
# 4. Change default ports if exposed to internet
# 5. Use a reverse proxy (nginx) with SSL/TLS certificates for production
# 6. Configure firewall rules to restrict access
# 7. Regularly update Docker images for security patches

